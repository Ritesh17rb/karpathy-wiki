<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="../style.css" />
  </head>
  <body>
    <header class="subpage-header">
      <a class="home-link" href="../index.html">Knowledge Index</a>
      <h1>{{ topic.title }}</h1>
      <p class="subtitle">{{ topic.summary }}</p>
      <ul class="tag-row">
        {% for keyword in topic.keywords[:8] %}
        <li>{{ keyword }}</li>
        {% endfor %}
      </ul>
    </header>

    <main class="subpage-layout">
      <section class="primary">
        <div class="card">
          <h2>Source Sections</h2>
          {% for section in sections %}
          <article class="section-entry">
            <h3>{{ section.title }}</h3>
            <p class="source-ref">
              <a href="../sources/{{ section.doc_id }}.html">{{ section.doc_title }}</a>
              · pages {{ section.start_page }}-{{ section.end_page }}
            </p>
            <p>{{ excerpt(section.text) }}</p>
          </article>
          {% endfor %}
        </div>
      </section>

      <aside class="secondary">
        <div class="card">
          <h2>Contributing Sources</h2>
          <ul class="link-list">
            {% for document in documents %}
            <li><a href="../sources/{{ document.doc_id }}.html">{{ document.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
        <div class="card">
          <h2>Related Topics</h2>
          <ul class="link-list">
            {% for item in related %}
            <li><a href="{{ item.topic_id }}.html">{{ item.title }}</a></li>
            {% else %}
            <li>No related topics detected.</li>
            {% endfor %}
          </ul>
        </div>
      </aside>
    </main>
  </body>
</html>
