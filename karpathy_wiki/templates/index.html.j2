<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="style.css" />
  </head>
  <body class="wiki-app" data-base-prefix="">
    <header class="chrome">
      <div class="chrome-inner">
        <div class="brand-block">
          <a class="app-home" href="index.html">{{ site_title }}</a>
          <p class="app-caption">{{ site_caption }}</p>
        </div>
        <nav class="top-nav" aria-label="Wiki navigation">
          {% for item in nav_pages %}
          <a href="{{ item.url }}"{% if current_slug == item.slug %} class="is-active"{% endif %}>{{ item.title }}</a>
          {% endfor %}
        </nav>
      </div>
    </header>

    <main class="page-grid home-grid">
      <aside class="sidebar stack">
        <section class="panel">
          <h2>Snapshot</h2>
          <dl class="stats-list">
            <div><dt>Documents</dt><dd>{{ document_total }}</dd></div>
            <div><dt>Retained sections</dt><dd>{{ section_total }}</dd></div>
            <div><dt>Topic pages</dt><dd>{{ topic_total }}</dd></div>
            <div><dt>Evidence links</dt><dd>{{ crosslink_total }}</dd></div>
            {% if build_meta.generated_at_display %}
            <div><dt>Latest compile</dt><dd>{{ build_meta.generated_at_display }}</dd></div>
            {% endif %}
            {% if build_meta.source_file_name %}
            <div><dt>Source list</dt><dd>{{ build_meta.source_file_name }}</dd></div>
            {% endif %}
          </dl>
        </section>

        <section class="panel">
          <h2>Article Index</h2>
          <p class="muted">Browse the loaded corpus immediately, or type to filter wiki, topic, and source pages.</p>
          <input id="searchBox" type="search" placeholder="Search the corpus" />
          <div id="searchResults" class="search-results">
            {% for item in explore_items %}
            <article class="search-hit">
              <a href="{{ item.url }}"><strong>{{ item.title }}</strong></a>
              <span>{{ item.type }}</span>
              <p>{{ item.summary }}</p>
            </article>
            {% endfor %}
          </div>
        </section>

        <section class="panel">
          <h2>Portal Pages</h2>
          <ul class="plain-list">
            {% for item in nav_pages if item.slug != "index" %}
            <li><a href="{{ item.url }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        </section>

        {% if topic_hubs %}
        <section class="panel">
          <h2>Topic Hubs</h2>
          <ul class="plain-list compact-list">
            {% for item in topic_hubs %}
            <li><a href="topics/{{ item.topic.topic_id }}.html">{{ item.topic.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}

        {% if source_hubs %}
        <section class="panel">
          <h2>Source Hubs</h2>
          <ul class="plain-list compact-list">
            {% for document in source_hubs %}
            <li><a href="sources/{{ document.doc_id }}.html">{{ document.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}

        <section class="panel">
          <h2>Editorial Notes</h2>
          <ul class="plain-list">
            <li>Raw sources remain immutable and act as ground truth.</li>
            <li>The wiki is a maintained artifact rather than per-query rediscovery.</li>
            <li>Topic pages link back to source sections that support them.</li>
            <li>`log` is append-only and `lint` is part of the normal maintenance loop.</li>
          </ul>
        </section>
      </aside>

      <article class="paper markdown-page">
        {{ page.content_html | safe }}
      </article>
    </main>

    <script id="searchIndex" type="application/json">{{ search_blob | safe }}</script>
    <script src="search.js"></script>
  </body>
</html>
