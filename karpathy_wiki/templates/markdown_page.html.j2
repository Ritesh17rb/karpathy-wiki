<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ page_title }}</title>
    <link rel="stylesheet" href="{{ base_prefix }}style.css" />
  </head>
  <body class="wiki-app" data-base-prefix="{{ base_prefix }}">
    <header class="chrome">
      <div class="chrome-inner">
        <div class="brand-block">
          <a class="app-home" href="{{ base_prefix }}index.html">{{ site_title }}</a>
          <p class="app-caption">{{ site_caption }}</p>
        </div>
        <nav class="top-nav" aria-label="Wiki navigation">
          {% for item in nav_pages %}
          <a href="{{ base_prefix }}{{ item.url }}"{% if current_slug == item.slug %} class="is-active"{% endif %}>{{ item.title }}</a>
          {% endfor %}
        </nav>
      </div>
    </header>

    <main class="page-grid home-grid">
      <aside class="sidebar stack">
        <section class="panel">
          <h2>This Page</h2>
          <ul class="plain-list compact-list">
            {% for item in page.headings %}
            <li><a href="#{{ item.anchor }}">{{ item.title }}</a></li>
            {% else %}
            <li>No section headings.</li>
            {% endfor %}
          </ul>
        </section>

        <section class="panel">
          <h2>Article Index</h2>
          <p class="muted">Browse the loaded corpus immediately, or type to filter wiki, topic, and source pages.</p>
          <input id="searchBox" type="search" placeholder="Search the corpus" />
          <div id="searchResults" class="search-results">
            {% for item in explore_items %}
            <article class="search-hit">
              <a href="{{ base_prefix }}{{ item.url }}"><strong>{{ item.title }}</strong></a>
              <span>{{ item.type }}</span>
              <p>{{ item.summary }}</p>
            </article>
            {% endfor %}
          </div>
        </section>

        {% if related_links %}
        <section class="panel">
          <h2>{{ related_heading }}</h2>
          <ul class="plain-list compact-list">
            {% for item in related_links %}
            <li><a href="{{ item.url }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}

        {% if portal_links %}
        <section class="panel">
          <h2>Browse Portals</h2>
          <ul class="plain-list compact-list portal-list">
            {% for item in portal_links %}
            <li><span>{{ item.kind }}:</span> <a href="{{ item.url }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}

        {% if evidence_links %}
        <section class="panel">
          <h2>Evidence Trail</h2>
          <ul class="plain-list compact-list">
            {% for item in evidence_links %}
            <li><a href="{{ item.url }}">{{ item.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}

        <section class="panel">
          <h2>Publication State</h2>
          <dl class="stats-list">
            {% if build_meta.generated_at_display %}
            <div><dt>Latest compile</dt><dd>{{ build_meta.generated_at_display }}</dd></div>
            {% endif %}
            {% if build_meta.source_file_name %}
            <div><dt>Source list</dt><dd>{{ build_meta.source_file_name }}</dd></div>
            {% endif %}
            {% if build_meta.log_entries %}
            <div><dt>Log entries</dt><dd>{{ build_meta.log_entries }}</dd></div>
            {% endif %}
            <div><dt>Documents</dt><dd>{{ document_total }}</dd></div>
            <div><dt>Topic pages</dt><dd>{{ topic_total }}</dd></div>
          </dl>
        </section>
      </aside>

      <article class="paper markdown-page">
        {% if page_kicker %}
        <p class="page-kicker">{{ page_kicker }}</p>
        {% endif %}
        {% if hatnote_links %}
        <nav class="hatnote" aria-label="{{ hatnote_heading }}">
          <span class="hatnote-label">{{ hatnote_heading }}:</span>
          {% for item in hatnote_links %}
          <a href="{{ item.url }}">{{ item.title }}</a>{% if not loop.last %} · {% endif %}
          {% endfor %}
        </nav>
        {% endif %}
        {{ page.content_html | safe }}
      </article>
    </main>

    <script id="searchIndex" type="application/json">{{ search_blob | safe }}</script>
    <script src="{{ base_prefix }}search.js"></script>
  </body>
</html>
